<div style="font-family:Arial,sans-serif;color:#333;max-width:700px;">
  <div style="background:<%= @is_approved ? "#16a34a" : "#dc2626" %>;color:#fff;padding:20px 30px;border-radius:8px 8px 0 0;">
    <h2 style="margin:0;font-size:1.2rem;">🏗️ SP Bedana &mdash; MRF <%= @is_approved ? raw("APPROVED &#x2705;") : raw("REJECTED &#x274C;") %></h2>
  </div>
  <div style="background:#fff;border:1px solid #ddd;padding:24px 30px;border-radius:0 0 8px 8px;">
    <p style="margin:0 0 6px;"><strong>MRF Control #:</strong> <%= @request_id %></p>
    <p style="margin:0 0 6px;"><strong>Project:</strong> <%= @project_name %></p>
    <p style="margin:0 0 16px;"><strong>Requestor:</strong> <%= @requestor_email %></p>
    <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
      <thead>
        <tr style="background:#f2f2f2;">
          <th style="border:1px solid #ddd;padding:8px;text-align:left;">Item</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:center;">Unit</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:center;">Req. Qty</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:center;">App. Qty</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:left;">Remarks</th>
        </tr>
      </thead>
      <tbody>
        <% @processed_items.each do |it| %>
          <tr>
            <td style="border:1px solid #ddd;padding:8px;"><%= it[:description] %></td>
            <td style="border:1px solid #ddd;padding:8px;text-align:center;"><%= it[:unit] %></td>
            <td style="border:1px solid #ddd;padding:8px;text-align:center;"><%= it[:reqQty] %></td>
            <td style="border:1px solid #ddd;padding:8px;text-align:center;">
              <% if @is_approved %>
                <% if it[:reqQty].to_f > 0 && it[:reqQty].to_f != it[:appQty].to_f %>
                  <span style="color:#dc2626;font-weight:bold;"><%= it[:appQty] %></span>
                <% else %>
                  <%= it[:appQty] %>
                <% end %>
              <% else %>
                &mdash;
              <% end %>
            </td>
            <td style="border:1px solid #ddd;padding:8px;"><%= it[:remarks].presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p style="margin-top:24px;font-size:0.8rem;color:#888;">
      This is an automated notification from the SP Bedana ERP portal.
    </p>
  </div>
</div>
