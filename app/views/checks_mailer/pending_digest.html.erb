<div style="font-family:Arial,sans-serif;color:#333;max-width:700px;">
  <div style="background:#0d1b2e;color:#fff;padding:20px 30px;border-radius:8px 8px 0 0;">
    <h2 style="margin:0;font-size:1.2rem;">🏦 SP Bedana &mdash; Checks Due for Deposit</h2>
  </div>
  <div style="background:#fff;border:1px solid #ddd;padding:24px 30px;border-radius:0 0 8px 8px;">
    <p style="margin:0 0 16px;">As of <strong><%= @today_str %></strong>, the following checks are due today or overdue and remain <strong>Not Deposited</strong>:</p>
    <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
      <thead>
        <tr style="background:#f2f2f2;">
          <th style="border:1px solid #ddd;padding:8px;text-align:left;">Check Date</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:left;">Project</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:left;">Bank</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:left;">Check #</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:right;">Amount</th>
          <th style="border:1px solid #ddd;padding:8px;text-align:center;">Status</th>
        </tr>
      </thead>
      <tbody>
        <% @due_checks.each do |c| %>
          <tr>
            <td style="border:1px solid #ddd;padding:8px;"><%= c[:date] %></td>
            <td style="border:1px solid #ddd;padding:8px;"><%= c[:project] %></td>
            <td style="border:1px solid #ddd;padding:8px;"><%= c[:bank] %></td>
            <td style="border:1px solid #ddd;padding:8px;"><%= c[:checkNumber] %></td>
            <td style="border:1px solid #ddd;padding:8px;text-align:right;">₱<%= number_with_delimiter(format("%.2f", c[:amount])) %></td>
            <td style="border:1px solid #ddd;padding:8px;text-align:center;color:<%= c[:statusColor] %>;font-weight:bold;"><%= c[:statusLabel] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p style="margin-top:24px;font-size:0.8rem;color:#888;">
      This is an automated notification from the SP Bedana ERP portal.
    </p>
  </div>
</div>
