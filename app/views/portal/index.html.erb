<!DOCTYPE html>
<html>
<head>
  <base target="_top">
    
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
  <%= csrf_meta_tags %>
  <%= stylesheet_link_tag "portal" %>
  
  <script>
    const CLIENT_NAME = "Vegastar";
    const RESET_TOKEN = "<%= j params[:resetToken].to_s %>";
    const SUKI_PO = "<%= j params[:sukiPo].to_s %>";
  </script>


  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      corePlugins: { preflight: false },
      theme: { extend: { colors: { alpha: { gold: '#f8b400', navy: '#0f172a' } } } }
    }
  </script>

</head>
<body>

<div id="auth-loading" class="lp-auth-overlay" style="display:none;">
  <div class="lp-auth-card">
    <div class="lp-logo lp-logo-sm"><img src="https://i.imgur.com/dhbq2a5.png" alt="Vegastar Logo"></div>
    <h3 class="lp-auth-title">Vegastar</h3>
    <div class="lp-auth-spinner">
      <svg class="lp-spin-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="lp-spin-track" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
        <path class="lp-spin-fill" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Authenticating...
    </div>
  </div>
</div>

<div id="auth-denied" class="lp-auth-overlay" style="display:none;">
  <div class="lp-auth-card">
    <div style="font-size: 3.5rem; margin-bottom: 0.75rem; line-height: 1;">🛑</div>
    <h2 class="lp-auth-title" style="color: #dc2626;">Access Denied</h2>
    <p id="denied-message" style="color: #64748b; font-size: 0.875rem; margin-top: 0.5rem; text-align: center; font-family: var(--body-font); max-width: 260px; line-height: 1.6;">You are not authorized to access this portal.</p>
  </div>
</div>

<div id="login-screen" class="lp-root" style="display:flex !important;">

  <!-- Left: Branding Panel -->
  <div class="lp-brand">
    <div class="lp-brand-inner">
      <div class="lp-logo"><img src="https://i.imgur.com/dhbq2a5.png" alt="Vegastar Logo"></div>
      <h1 class="lp-brand-name">Vegastar</h1>
      <p class="lp-brand-tagline">Enterprise Resource Portal</p>
      <div class="lp-brand-divider"></div>
      <p class="lp-brand-desc">A centralized platform for construction project management — from BOQ ingestion to payment tracking, all in one place.</p>
      <div class="lp-brand-features">
        <div class="lp-feature-item">
          <span class="lp-feature-icon">📋</span>
          <span>BOQ &amp; Material Management</span>
        </div>
        <div class="lp-feature-item">
          <span class="lp-feature-icon">📦</span>
          <span>Purchase Orders &amp; RFQs</span>
        </div>
        <div class="lp-feature-item">
          <span class="lp-feature-icon">💳</span>
          <span>Accounting &amp; Payments</span>
        </div>
      </div>
    </div>
    <div class="lp-deco-circle lp-deco-1"></div>
    <div class="lp-deco-circle lp-deco-2"></div>
  </div>

  <!-- Right: Form Panel -->
  <div class="lp-form-panel">
    <div class="lp-form-inner">

      <div class="lp-form-header">
        <div class="lp-form-logo-sm"><img src="https://i.imgur.com/dhbq2a5.png" alt="Vegastar Logo"></div>
        <h2 class="lp-form-title">Welcome back</h2>
        <p class="lp-form-subtitle">Sign in to your account to continue</p>
      </div>

      <div id="login-alert" class="toast-notification" style="display:none;" role="alert"></div>

      <div class="lp-field">
        <label class="lp-label" for="loginEmail">Email Address</label>
        <input type="email" id="loginEmail" class="lp-input" placeholder="you@vegastar.com" required>
      </div>

      <div class="lp-field">
        <div class="lp-label-row">
          <label class="lp-label" for="loginPassword">Password</label>
          <a href="#" class="lp-link-forgot" onclick="forgotPassword(); return false;">Forgot password?</a>
        </div>
        <div class="lp-input-wrap">
          <input type="password" id="loginPassword" class="lp-input" placeholder="Enter your password" required>
          <button type="button" class="lp-eye-btn" onclick="var i=this.previousElementSibling; i.type=i.type==='password'?'text':'password';" title="Toggle password visibility" tabindex="-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>

      <button id="loginBtn" onclick="attemptLogin()" class="lp-btn-login">
        Sign In
      </button>

      <p class="lp-security-note">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Secured with enterprise-grade authentication
      </p>
    </div>
  </div>
</div>

<div id="reset-screen" class="lp-auth-overlay" style="display:none !important;">
  <div class="lp-auth-card lp-reset-card">
    <div style="font-size: 2.75rem; line-height: 1; margin-bottom: 0.85rem;">🔐</div>
    <h3 class="lp-auth-title">Set New Password</h3>
    <p style="color: #64748b; font-size: 0.875rem; margin: 0.5rem 0 1.5rem; text-align: center; font-family: var(--body-font); line-height: 1.6;">Create a new secure password for your account</p>
    <div id="reset-alert" class="alert alert-danger py-2" style="display:none; font-size: 0.85rem; width: 100%;"></div>
    <div class="lp-field" style="width: 100%;">
      <label class="lp-label" for="newPassword">New Password</label>
      <input type="password" id="newPassword" class="lp-input" placeholder="••••••••">
    </div>
    <div class="lp-field" style="width: 100%;">
      <label class="lp-label" for="confirmPassword">Confirm Password</label>
      <input type="password" id="confirmPassword" class="lp-input" placeholder="••••••••">
    </div>
    <button id="resetSubmitBtn" class="lp-btn-login" style="margin-top: 0.25rem;" onclick="submitNewPassword()">Update Password</button>
    <div style="text-align: center; margin-top: 1.25rem;">
      <a href="javascript:void(0)" onclick="window.top.location.href=window.top.location.href.split('?')[0];" class="lp-link-forgot">← Back to Login</a>
    </div>
  </div>
</div>

<div id="supplier-screen" class="d-flex justify-content-center align-items-center" style="display:none !important; min-height:100vh; padding: 20px;">
  <div class="card shadow-sm p-4" style="width: 100%; max-width: 800px; border-radius: 12px; border: none;">
    <h3 class="fw-bold text-dark text-center">Supplier Pricing Entry</h3>
    <p class="text-muted text-center" id="suki-po-subtitle">PO Number: Loading...</p>
    
    <div class="table-responsive mt-3">
       <table class="table table-bordered table-sm align-middle">
         <thead class="table-light"><tr><th>Item</th><th>Unit</th><th>App. Qty</th><th>Price/Amount</th><th>Line Total</th></tr></thead>
         <tbody id="suki-item-body"></tbody>
         <tfoot class="fw-bold"><tr><th colspan="4" class="text-end">Grand Total:</th><th id="suki-grand-total">₱0.00</th></tr></tfoot>
       </table>
    </div>
    <button id="sukiSubmitBtn" class="btn btn-primary w-100 fw-bold py-2 mt-3" onclick="submitSuki()">Send Pricing</button>
  </div>
</div>


<div id="app-content" style="display:none;">
  
  <div class="top-nav">
    <div class="logo-section">
      <div class="logo-icon"><img src="https://i.imgur.com/dhbq2a5.png" alt="Vegastar Logo"></div>
      <div class="logo-text">Vegastar</div>
    </div>
    
    <div class="nav-links d-flex align-items-center">
      <div class="dropdown" id="nav-group-boq" style="display:none;">
        <a class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">BOQ Ingestor</a>
        <ul class="dropdown-menu">
          <li data-permission="boq"><a class="dropdown-item" id="nav-boq" onclick="showSection('boq')">Upload Excel File</a></li>
          <li data-permission="boq"><a class="dropdown-item" id="nav-build-boq" onclick="showSection('build-boq')">Build BOQ</a></li>
        </ul>
      </div>
      <a id="nav-expense" data-permission="expense" onclick="showSection('expense')">Expense Log</a>

      <!-- Group wrapper has no data-permission — JS collapses it when all children are hidden -->
      <div class="dropdown" id="nav-group-site-engineer" style="display:none;">
        <a class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">Site Engineer</a>
        <ul class="dropdown-menu">
          <li data-permission="site engineer"><a class="dropdown-item" id="nav-material" onclick="showSection('material')">Material Request</a></li>
          <li data-permission="site engineer"><a class="dropdown-item" id="nav-receiving" onclick="showSection('receiving')">Receiving</a></li>
          <!-- Petty Cash is accessible via full site-engineer role OR the narrower record-petty-cash permission -->
          <li data-permission="site engineer|record petty cash"><a class="dropdown-item" id="nav-petty-cash" onclick="showSection('petty-cash')">Request Reimbursement</a></li>
        </ul>
      </div>

      <div class="dropdown" id="nav-group-project-engineer" style="display:none;">
        <a class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">Project Engineer</a>
        <ul class="dropdown-menu">
          <li data-permission="project engineer|admin"><a class="dropdown-item" id="nav-project-engineer" onclick="showSection('project-engineer')">Project Progress &amp; RTB</a></li>
        </ul>
      </div>

      <div class="dropdown" id="nav-group-subcontractor" style="display:none;">
        <a class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">Subcontractor</a>
        <ul class="dropdown-menu">
          <li data-permission="subcontractor"><a class="dropdown-item" id="nav-subcontractor-ap" onclick="showSection('subcontractor-ap')">Subcontractor AP</a></li>
          <li data-permission="subcontractor"><a class="dropdown-item" id="nav-assign-wp" onclick="showSection('assign-wp')">Assign Work Package</a></li>
          <li data-permission="subcontractor reports|subcontractor"><a class="dropdown-item" id="nav-subcontractor-reports" onclick="showSection('subcontractor-reports')">Subcontractor Reports</a></li>
          <li data-permission="subcontractor"><a class="dropdown-item" id="nav-subcontract-budget" onclick="showSection('subcontract-budget')">Budget vs Actual</a></li>
        </ul>
      </div>

      <div class="dropdown" id="nav-group-material-requests" style="display:none;">
        <a class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">Procurement</a>
        <ul class="dropdown-menu">
          <li data-permission="material requests"><a class="dropdown-item" id="nav-approvals" onclick="showSection('approvals')">Approvals Queue</a></li>
          <li data-permission="material requests"><a class="dropdown-item" id="nav-rfq" onclick="showSection('rfq')">RFQs</a></li>
          <li data-permission="material requests"><a class="dropdown-item" id="nav-bid-tab" onclick="showSection('bid-tab')">Encode Quotes</a></li>
          <li data-permission="material requests"><a class="dropdown-item" id="nav-canvas" onclick="showSection('canvas')">Canvas & Award</a></li>
          <li data-permission="material requests"><a class="dropdown-item" id="nav-purchase-orders" onclick="showSection('purchase-orders')">Purchase Orders</a></li>
          <li data-permission="material requests"><a class="dropdown-item" id="nav-historical-pricing" onclick="showSection('historical-pricing')">Historical Pricing</a></li>
        </ul>
      </div>

      <div class="dropdown" id="nav-group-payments" style="display:none;">
        <a class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">Accounting</a>
        <ul class="dropdown-menu">
          <li data-permission="payments"><a class="dropdown-item" id="nav-payments" onclick="showSection('payments')">Bulk Payments</a></li>
          <li data-permission="payments"><a class="dropdown-item" id="nav-checks" onclick="showSection('checks')">Pending Checks</a></li>
          <li data-permission="petty cash ledger"><a class="dropdown-item" id="nav-pc-ledger" onclick="showSection('pc-ledger')">Reimbursement Ledger</a></li>
          <li data-permission="boq-adjust"><a class="dropdown-item" id="nav-boq-adjust" onclick="showSection('boq-adjust')">BOQ Adjustments</a></li>
          <li data-permission="compute project cost"><a class="dropdown-item" id="nav-compute-cost" onclick="showSection('compute-cost')">Compute Cost</a></li>
          <li data-permission="supplier data"><a class="dropdown-item" id="nav-supplier-data" onclick="showSection('supplier-data')">Supplier Data</a></li>
          <li data-permission="issue payments"><a class="dropdown-item" id="nav-issue-payments" onclick="showSection('issue-payments')">Issue Payments</a></li>
          <li data-permission="refundable expenses"><a class="dropdown-item" id="nav-refundable-expenses" onclick="showSection('refundable-expenses')">Refundable Expenses</a></li>
          <li data-permission="payments|admin"><a class="dropdown-item" id="nav-collections" onclick="showSection('collections')">Project Payment Collection</a></li>
          <li data-permission="payments|subcontractor"><a class="dropdown-item" id="nav-subcon-payables" onclick="showSection('subcon-payables')">Subcontractor Payables</a></li>
        </ul>
      </div>
      <a id="nav-rtb-approvals" data-permission="rtb-approvals" onclick="showSection('rtb-approvals')">RTB Approvals</a>
    </div> <div class="user-profile">
      <span id="user-display-name">Loading...</span>
      <button onclick="logout()" class="btn btn-sm btn-outline-danger ms-2" style="font-size: 0.75rem; padding: 0.25rem 0.75rem;">Log Out</button>
    </div>
  </div>


  <div class="main-container">

    <div id="section-supplier-data" class="content-section">
      <h2 class="page-title">Supplier Database</h2>
      
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card shadow-sm border-0 h-100 bg-white">
            <div class="card-header bg-white border-bottom py-3">
              <h6 class="mb-0 fw-bold text-primary">➕ Register New Supplier</h6>
            </div>
            <div class="card-body p-4">
              <div id="supplier-alert" class="alert py-2" style="display:none; font-size: 0.85rem;"></div>
              
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted">Company / Supplier Name <span>*</span></label>
                <input type="text" id="supName" class="form-control form-control-sm" placeholder="e.g. Hardware Corp">
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted">Contact Person <span>*</span></label>
                <input type="text" id="supContact" class="form-control form-control-sm" placeholder="e.g. Juan Dela Cruz">
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted">Email Address <span>*</span> (Used for POs)</label>
                <input type="email" id="supEmail" class="form-control form-control-sm" placeholder="juandelacruz@gmail.com">
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label small fw-bold text-muted">Phone Number</label>
                  <input type="text" id="supPhone" class="form-control form-control-sm" placeholder="09XX XXX XXXX">
                </div>
                <div class="col-6">
                  <label class="form-label small fw-bold text-muted">TIN</label>
                  <input type="text" id="supTin" class="form-control form-control-sm" placeholder="XXX-XXX-XXX-XXX">
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted">Category / Specialty</label>
                <input type="text" id="supCategory" class="form-control form-control-sm" placeholder="e.g. Electrical, Rental">
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted">Business Address</label>
                <input type="text" id="supAddress" class="form-control form-control-sm" placeholder="Complete address">
              </div>
              <div class="mb-4">
                <label class="form-label small fw-bold text-muted">Bank Details</label>
                <textarea id="supBank" class="form-control form-control-sm" rows="2" placeholder="Bank Name, Account Name, Account No."></textarea>
              </div>
              
              <button id="supSubmitBtn" class="btn btn-primary w-100 fw-bold py-2" onclick="submitSupplier()">Save Supplier</button>
            </div>
          </div>
        </div>

        <div class="col-lg-8">
          <div class="card shadow-sm border-0 h-100 bg-white">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
              <h6 class="mb-0 fw-bold">Supplier Directory</h6>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive" style="max-height: 700px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
                  <thead class="table-light text-muted sticky-top" style="font-size: 0.75rem; text-transform: uppercase;">
                    <tr>
                      <th class="ps-4">Company Name</th>
                      <th>Contact Details</th>
                      <th>Category</th>
                      <th>TIN</th>
                    </tr>
                  </thead>
                  <tbody id="supplierTableBody">
                    <tr><td colspan="4" class="text-center py-4 text-muted">Loading suppliers...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>


    <div id="section-boq-adjust" class="content-section">
      <h2 class="page-title">BOQ Adjustments & Additions</h2>

      <div class="card shadow-sm border-0 mb-4" id="boq-approvals-card" style="display:none;">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
          <h6 class="mb-0 fw-bold">📥 Pending BOQ Approvals</h6>
          <button class="btn btn-sm btn-outline-secondary fw-bold" onclick="loadPendingBoqApprovals()">&#8635; Refresh</button>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:0.85rem;">
              <thead class="table-light text-muted" style="font-size:0.72rem;text-transform:uppercase;">
                <tr>
                  <th class="ps-4">Submission</th>
                  <th>Project</th>
                  <th>Customer</th>
                  <th>Company</th>
                  <th class="text-center">Items</th>
                  <th class="text-end">Grand Total</th>
                  <th>Submitter</th>
                  <th class="text-center pe-3">Actions</th>
                </tr>
              </thead>
              <tbody id="boq-approvals-body">
                <tr><td colspan="8" class="text-center py-4 text-muted">Loading...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="row mb-4">
        <div class="col-md-6">
          <label class="form-label fw-bold small text-muted">Select Project to Modify</label>
          <select class="form-select" id="boqAdjustProjectSelect" onchange="loadBoqAdjustItems()">
            <option value="">— Select Project —</option>
          </select>
        </div>
      </div>

      <div id="boq-adjust-workspace" style="display:none;">
        <div class="row g-4">
          <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
              <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 fw-bold">Current BOQ Items (Select to Reduce/Adjust)</h6>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                  <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
                    <thead class="table-light text-muted sticky-top" style="font-size: 0.75rem; text-transform: uppercase;">
                      <tr>
                        <th class="ps-3">Phase / Item</th>
                        <th>Unit</th>
                        <th class="text-end">Mat Cost</th>
                        <th class="text-end">Lab Cost</th>
                        <th class="text-center">Action</th>
                      </tr>
                    </thead>
                    <tbody id="boqAdjustTableBody">
                      <tr><td colspan="5" class="text-center py-4 text-muted">Loading items...</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100 bg-light">
              <div class="card-body p-4">
                <h6 class="fw-bold mb-3 text-success">➕ Add New Item</h6>
                <div id="boq-add-alert" class="alert py-2" style="display:none; font-size: 0.85rem;"></div>
                
                <div class="mb-2">
                  <label class="form-label small fw-bold text-muted">Phase</label>
                  <input type="text" id="addBoqPhase" class="form-control form-control-sm" placeholder="e.g. I. GENERAL REQUIREMENTS">
                </div>
                <div class="mb-2">
                  <label class="form-label small fw-bold text-muted">Item Description</label>
                  <input type="text" id="addBoqDesc" class="form-control form-control-sm" placeholder="Item name...">
                </div>
                <div class="row g-2 mb-2">
                  <div class="col-6">
                    <label class="form-label small fw-bold text-muted">Unit</label>
                    <input type="text" id="addBoqUnit" class="form-control form-control-sm" placeholder="e.g. sq.m, lot">
                  </div>
                  <div class="col-6">
                    <label class="form-label small fw-bold text-muted">Quantity</label>
                    <input type="number" id="addBoqQty" class="form-control form-control-sm" placeholder="0">
                  </div>
                </div>
                <div class="row g-2 mb-3">
                  <div class="col-6">
                    <label class="form-label small fw-bold text-muted">Materials Cost</label>
                    <input type="number" id="addBoqMat" class="form-control form-control-sm" placeholder="₱0.00">
                  </div>
                  <div class="col-6">
                    <label class="form-label small fw-bold text-muted">Labor Cost</label>
                    <input type="number" id="addBoqLab" class="form-control form-control-sm" placeholder="₱0.00">
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label small fw-bold text-muted">Reason for Addition</label>
                  <textarea id="addBoqReason" class="form-control form-control-sm" rows="2" placeholder="Explain why this item is being added..."></textarea>
                </div>
                <button id="addBoqBtn" class="btn btn-success btn-sm w-100 fw-bold" onclick="submitAddBoqItem()">Save New Item</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="adjustBoqModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
          <div class="modal-header bg-warning bg-opacity-25">
            <h5 class="modal-title fw-bold">Reduce / Adjust BOQ Item</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4">
